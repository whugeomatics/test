{
  "schemaVersion": 1,
  "sources": {
    "allowedTypes": ["github-webhook", "code-review", "scan-finding"],
    "allowedTriggers": ["comment", "label", "api", "scan"]
  },
  "paths": {
    "allowed": ["src/", "test/", "tests/", "pom.xml"],
    "blocked": [".github/", "infra/", "terraform/", ".env", ".npmrc"]
  },
  "commands": {
    "allowAutoDetect": true,
    "test": "mvn clean test",
    "build": "mvn clean package"
  },
  "changeRequest": {
    "autoCreate": true
  }
}